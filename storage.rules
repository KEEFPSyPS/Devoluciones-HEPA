rules_version = '2';

// ============================================================
// REGLAS DE SEGURIDAD PARA STORAGE - DEVOLUCIONES-HEPA
// ============================================================
// Por ahora no se usa Storage en la app, pero estas reglas
// están preparadas para cuando se necesite.
// ============================================================

// DENEGAR TODO POR DEFECTO - Solo usuarios autenticados
// Si en el futuro necesitas subir imágenes (ej. fotos de devoluciones),
// puedes descomentar y ajustar las reglas según necesites.

// Servicio no utilizado actualmente
match /b/{bucket}/o {
    match /{allPaths=**} {
        allow read, write: if false;
    }
}

