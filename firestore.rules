rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // REGLAS SIMPLIFICADAS - DEVOLUCIONES-HEPA
    // ============================================================
    // Solo usuarios autenticados pueden acceder a cualquier dato
    // ============================================================

    match /devoluciones/{document} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
            && request.resource.data.keys().hasAll(['folio', 'proveedor', 'quien_reporta', 'departamento', 'num_articulo', 'descripcion', 'cantidad', 'num_factura', 'motivo', 'fecha', 'status'])
            && request.resource.data.folio is string
            && request.resource.data.proveedor is string
            && request.resource.data.quien_reporta is string
            && request.resource.data.departamento in ['VOLKSWAGEN', 'NISSAN', 'CHEVROLET', 'TOYOTA', 'RENAULT']
            && request.resource.data.num_articulo is string
            && request.resource.data.descripcion is string
            && request.resource.data.cantidad is number
            && request.resource.data.num_factura is string
            && request.resource.data.motivo is string
            && request.resource.data.fecha is string
            && request.resource.data.status == 'Pendiente';
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
    }

    match /proveedores/{document} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
            && request.resource.data.nombre is string
            && request.resource.data.nombre.size() > 0;
        allow update: if request.auth != null
            && request.resource.data.nombre is string
            && request.resource.data.nombre.size() > 0;
        allow delete: if request.auth != null;
    }

    match /empleados/{document} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
            && request.resource.data.nombre is string
            && request.resource.data.nombre.size() > 0;
        allow update: if request.auth != null
            && request.resource.data.nombre is string
            && request.resource.data.nombre.size() > 0;
        allow delete: if request.auth != null;
    }
  }
}
